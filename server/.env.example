PORT=4000

# Base de datos MySQL. En Hostinger la creas en hPanel → Bases de datos MySQL.
# DB_HOST suele ser "localhost" cuando la app corre en el mismo hosting que la BD.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Clave que debe enviar el panel de admin en el header x-admin-key
ADMIN_KEY=cambia-esta-clave

# Opción A (recomendada — la única que no cae en spam sin dominio propio):
# Gmail API vía OAuth2. Envía por HTTPS (funciona en Render) y sale
# autenticado de verdad por Google. Ver instrucciones en el README.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=

# Opción B: SendGrid — envía por HTTPS (funciona en Render), pero si el remitente
# es una dirección @gmail.com sin dominio propio autenticado, es común que caiga en spam.
# Verifica el remitente en https://app.sendgrid.com/settings/sender_auth/senders (sin DNS).
SENDGRID_API_KEY=
FROM_EMAIL=entrevistas@ucab.edu.ve

# Opción C (funciona en local, NO funciona en Render — bloquea SMTP saliente): Gmail SMTP
# GMAIL_APP_PASSWORD es una "contraseña de aplicación" generada en
# https://myaccount.google.com/apppasswords (requiere verificación en 2 pasos). NO es tu contraseña normal.
GMAIL_APP_PASSWORD=

# Opción D: https://resend.com — requiere verificar un dominio propio (no funciona con @gmail.com)
RESEND_API_KEY=

# Si ninguna de las anteriores está configurada, los correos se simulan en la consola del servidor

# URL pública donde corre el frontend (para armar el enlace de agendamiento)
APP_BASE_URL=http://localhost:5173
