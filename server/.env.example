PORT=4000

# Clave que debe enviar el panel de admin en el header x-admin-key
ADMIN_KEY=cambia-esta-clave

# Opción A (recomendada para producción/Render): SendGrid — envía por HTTPS,
# funciona en hostings que bloquean SMTP saliente. Verifica el remitente en
# https://app.sendgrid.com/settings/sender_auth/senders (sin necesidad de DNS).
SENDGRID_API_KEY=
FROM_EMAIL=entrevistas@ucab.edu.ve

# Opción B (funciona en local, NO funciona en Render — bloquea SMTP saliente): Gmail SMTP
# GMAIL_USER es la cuenta de Gmail que envía, GMAIL_APP_PASSWORD es una
# "contraseña de aplicación" generada en https://myaccount.google.com/apppasswords
# (requiere tener la verificación en 2 pasos activada). NO es tu contraseña normal.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Opción C: https://resend.com — requiere verificar un dominio propio (no funciona con @gmail.com)
RESEND_API_KEY=

# Si ninguna de las anteriores está configurada, los correos se simulan en la consola del servidor

# URL pública donde corre el frontend (para armar el enlace de agendamiento)
APP_BASE_URL=http://localhost:5173
